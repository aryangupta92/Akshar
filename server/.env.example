# Copy this file to .env and fill in your values
PORT=5000
CLIENT_URL=http://localhost:5173

# MongoDB Atlas connection string (get from cloud.mongodb.com)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/akshar

# JWT secrets (change these to random long strings in production)
JWT_SECRET=your-secret-key-here
JWT_REFRESH_SECRET=your-refresh-secret-here

# Redis (optional — needed for version archiving feature)
# REDIS_URL=redis://localhost:6379
