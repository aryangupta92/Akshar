{
  "compilerOptions": {
    "target":                     "ES2020",
    "module":                     "commonjs",
    "lib":                        ["ES2020"],
    "outDir":                     "./dist",
    "rootDir":                    "./",
    "strict":                     true,
    "esModuleInterop":            true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck":               true,
    "resolveJsonModule":          true,
    "ignoreDeprecations":         "5.0"
  },
  "include": ["src/**/*", "worker.ts"],
  "exclude": ["node_modules", "dist"]
}
