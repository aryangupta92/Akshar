{
  "name": "akshar-server",
  "version": "1.0.0",
  "description": "Akshar – Lyricist & Story Writer Platform – Express/MongoDB backend",
  "main": "src/index.ts",
  "type": "commonjs",
  "scripts": {
    "dev":    "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "worker": "ts-node worker.ts",
    "build":  "tsc --outDir dist",
    "start":  "node dist/src/index.js"
  },
  "dependencies": {
    "bcryptjs":      "^3.0.3",
    "bullmq":        "^5.76.8",
    "cookie-parser": "^1.4.7",
    "cors":          "^2.8.6",
    "dotenv":        "^17.4.2",
    "express":       "^5.2.1",
    "ioredis":       "^5.10.1",
    "jsonwebtoken":  "^9.0.3",
    "mongoose":      "^9.6.2"
  },
  "devDependencies": {
    "@types/bcryptjs":       "^2.4.6",
    "@types/cookie-parser":  "^1.4.10",
    "@types/cors":           "^2.8.19",
    "@types/express":        "^5.0.6",
    "@types/jsonwebtoken":   "^9.0.10",
    "@types/node":           "^25.7.0",
    "nodemon":               "^3.1.14",
    "ts-node":               "^10.9.2",
    "typescript":            "^6.0.3"
  }
}
